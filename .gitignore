# ==========================================
# 1. PYTHON BYTE-CODE & VIRTUAL ENVIRONMENTS
# ==========================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Virtual Environment
# IMPORTANT: Replace 'venv' with the name of your virtual environment folder
venv/
env/
ENV/
.venv/

# ==========================================
# 2. DATA FILES (The Heavy Stuff)
# ==========================================

# Ignore all data in the ml_pipelines folder
!ml_pipelines/data/raw/*
!ml_pipelines/data/raw/.gitkeep
!ml_pipelines/data/processed/*
!ml_pipelines/data/processed/.gitkeep

# Ignore specific heavy file types everywhere
!*.csv
*.mat
*.zip
*.parquet
*.hdf5

# EXCEPTION: Keep small sample datasets if you add them later
# !ml_pipelines/data/raw/sample_data.csv

# ==========================================
# 3. ML MODELS & ARTIFACTS
# ==========================================

# Ignore serialized models (Pickles, Joblib, Tensorflow weights)
# These can get large and are better stored in cloud storage (AWS S3) or Git LFS
models/*.pkl
models/*.joblib
models/*.h5
models/*.pt

# Ignore logs
*.log

# ==========================================
# 4. JUPYTER NOTEBOOKS
# ==========================================

# Ipynb checkpoints (hidden files created by Jupyter)
.ipynb_checkpoints/

# ==========================================
# 5. IDE & EDITOR SETTINGS
# ==========================================

# VS Code
.vscode/

# PyCharm
.idea/

# ==========================================
# 6. ENVIRONMENT & SECRETS
# ==========================================

# Environment variables (Database URLs, API Keys)
.env

# OS generated files
.DS_Store
Thumbs.db